#!/bin/bash
# isambard_sbatch - A wrapper around sbatch that enforces project-wide node limits
#
# Checks total node usage (running + pending) across all users in a SLURM
# account before allowing submission. Blocks if the project would exceed
# the configured maximum.
#
# Environment variables:
#   ISAMBARD_SBATCH_MAX_NODES       - Max nodes for the account (default: 128)
#   ISAMBARD_SBATCH_ACCOUNT         - SLURM account to check (default: brics.a5k)
#   ISAMBARD_SBATCH_DRY_RUN         - If 1, print what would happen without submitting
#   ISAMBARD_SBATCH_FORCE           - If 1, bypass the check entirely
#   ISAMBARD_SBATCH_DISABLED        - If 1, pass through to real sbatch (no checking)
#   ISAMBARD_SBATCH_BAD_NODES_FILE  - Shared log of bad nodes to exclude
#                                     (default: /projects/a5k/public/isambard_sbatch_bad_nodes.log)
#   ISAMBARD_SBATCH_BAD_NODES_TTL   - Seconds before a bad-node entry expires (default: 604800 = 7 days)

set -euo pipefail

MAX_NODES="${ISAMBARD_SBATCH_MAX_NODES:-128}"
ACCOUNT="${ISAMBARD_SBATCH_ACCOUNT:-brics.a5k}"
DRY_RUN="${ISAMBARD_SBATCH_DRY_RUN:-0}"
FORCE="${ISAMBARD_SBATCH_FORCE:-0}"
DISABLED="${ISAMBARD_SBATCH_DISABLED:-0}"
BAD_NODES_FILE="${ISAMBARD_SBATCH_BAD_NODES_FILE:-/projects/a5k/public/isambard_sbatch_bad_nodes.log}"
BAD_NODES_TTL="${ISAMBARD_SBATCH_BAD_NODES_TTL:-604800}"

# Find the real sbatch binary, skipping our own directory
find_real_sbatch() {
    local our_dir
    our_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local IFS=':'
    for dir in $PATH; do
        if [[ "$dir" != "$our_dir" && -x "$dir/sbatch" ]]; then
            echo "$dir/sbatch"
            return
        fi
    done
    # Fallback to known location
    if [[ -x /usr/bin/sbatch ]]; then
        echo "/usr/bin/sbatch"
        return
    fi
    echo ""
}

REAL_SBATCH="$(find_real_sbatch)"
if [[ -z "$REAL_SBATCH" ]]; then
    echo "isambard_sbatch: error: real sbatch not found in PATH" >&2
    exit 127
fi

# Parse requested node count from command-line arguments.
# Returns the node count or empty string if not specified.
parse_nodes_from_args() {
    local nodes=""
    local i=0
    local args=("$@")

    while [[ $i -lt ${#args[@]} ]]; do
        case "${args[$i]}" in
            --nodes=*)
                nodes="${args[$i]#--nodes=}"
                ;;
            --nodes|-N)
                i=$((i + 1))
                if [[ $i -lt ${#args[@]} ]]; then
                    nodes="${args[$i]}"
                fi
                ;;
            -N[0-9]*)
                nodes="${args[$i]#-N}"
                ;;
        esac
        i=$((i + 1))
    done

    echo "$nodes"
}

# Parse requested node count from #SBATCH directives in a batch script.
# Uses the last occurrence (matching real sbatch behavior).
parse_nodes_from_script() {
    local script="$1"
    if [[ ! -f "$script" ]]; then
        echo ""
        return
    fi

    local nodes=""
    while IFS= read -r line; do
        # Strip leading whitespace
        line="${line#"${line%%[![:space:]]*}"}"
        case "$line" in
            "#SBATCH --nodes="*)
                nodes="${line#*--nodes=}"
                nodes="${nodes%% *}"
                ;;
            "#SBATCH -N "*)
                nodes="${line#*-N }"
                nodes="${nodes%% *}"
                ;;
            "#SBATCH -N"[0-9]*)
                local rest="${line#*-N}"
                rest="${rest%% *}"
                if [[ "$rest" =~ ^[0-9]+(-[0-9]+)?$ ]]; then
                    nodes="$rest"
                fi
                ;;
        esac
    done < "$script"

    echo "$nodes"
}

# Find the batch script file from arguments.
# The script is the first positional argument (non-option).
find_script_file() {
    local i=0
    local args=("$@")

    # Options that consume the next argument as a value
    local -A opts_with_value=(
        [--nodes]=1 [--ntasks]=1 [--cpus-per-task]=1 [--mem]=1 [--time]=1
        [--partition]=1 [--output]=1 [--error]=1 [--job-name]=1 [--account]=1
        [--dependency]=1 [--gres]=1 [--constraint]=1 [--mem-per-cpu]=1
        [--mem-per-gpu]=1 [--gpus]=1 [--gpus-per-node]=1 [--gpus-per-task]=1
        [--begin]=1 [--deadline]=1 [--signal]=1 [--mail-type]=1 [--mail-user]=1
        [--reservation]=1 [--nodefile]=1 [--exclude]=1 [--nice]=1 [--priority]=1
        [--qos]=1 [--wckey]=1 [--licenses]=1 [--clusters]=1 [--comment]=1
        [--distribution]=1 [--export]=1 [--extra-node-info]=1 [--hint]=1
        [--mcs-label]=1 [--network]=1 [--open-mode]=1 [--power]=1
        [--profile]=1 [--propagate]=1 [--switches]=1 [--thread-spec]=1
        [--tmp]=1 [--wait-all-nodes]=1 [--chdir]=1 [--workdir]=1 [--wrap]=1
        [-N]=1 [-n]=1 [-c]=1 [-p]=1 [-t]=1 [-o]=1 [-e]=1 [-J]=1 [-A]=1
        [-w]=1 [-x]=1 [-D]=1 [-d]=1
    )

    while [[ $i -lt ${#args[@]} ]]; do
        local arg="${args[$i]}"
        case "$arg" in
            --*=*)
                # --option=value, no next arg consumed
                ;;
            --*)
                # Check if this long option takes a value
                if [[ -n "${opts_with_value[$arg]+x}" ]]; then
                    i=$((i + 1))  # skip the value
                fi
                ;;
            -[A-Za-z])
                # Single short option like -N, -p, etc.
                if [[ -n "${opts_with_value[$arg]+x}" ]]; then
                    i=$((i + 1))  # skip the value
                fi
                ;;
            -[A-Za-z]*)
                # Short option with value attached (-N4, -J name), skip
                ;;
            *)
                # First positional argument — this is the script
                echo "$arg"
                return
                ;;
        esac
        i=$((i + 1))
    done

    echo ""
}

# Resolve node ranges (e.g., "2-4") to the maximum value.
resolve_node_count() {
    local nodes="$1"
    if [[ "$nodes" == *-* ]]; then
        echo "${nodes##*-}"
    else
        echo "$nodes"
    fi
}

# Get current node usage (running + pending) for the configured account.
get_current_nodes() {
    squeue -A "$ACCOUNT" -h -t RUNNING,PENDING -o "%D" 2>/dev/null \
        | awk '{sum+=$1} END {print sum+0}'
}

# Get per-user node breakdown for the configured account.
# Output: one line per user, sorted by node count descending.
#   "username  <running_nodes>R  <pending_nodes>P  <total_nodes> total"
get_per_user_breakdown() {
    squeue -A "$ACCOUNT" -h -t RUNNING,PENDING -o "%u %D %T" 2>/dev/null \
        | awk '
    {
        user = $1; nodes = $2; state = $3
        total[user] += nodes
        if (state == "RUNNING") running[user] += nodes
        else pending[user] += nodes
    }
    END {
        # Sort by total descending (collect into arrays, bubble sort)
        n = 0
        for (u in total) { n++; users[n] = u; tots[n] = total[u] }
        for (i = 1; i <= n; i++)
            for (j = i + 1; j <= n; j++)
                if (tots[j] > tots[i]) {
                    tmp = tots[i]; tots[i] = tots[j]; tots[j] = tmp
                    tmp = users[i]; users[i] = users[j]; users[j] = tmp
                }
        for (i = 1; i <= n; i++) {
            u = users[i]
            r = running[u] + 0
            p = pending[u] + 0
            t = total[u]
            printf "    %-20s  %4dR  %4dP  %4d total\n", u, r, p, t
        }
    }'
}

# Print a compact cluster + account summary to stderr.
print_cluster_summary() {
    local current_nodes="$1"
    local requested_nodes="$2"

    # Cluster-wide node counts by state. Strip SLURM state suffixes
    # (*, ~, #, $, @, %, +, -) before bucketing so "mixed-", "drained$",
    # "down*" etc. don't silently fall off the table.
    local cluster_stats
    cluster_stats=$(sinfo -o "%T %D %G" --noheader 2>/dev/null | awk '
    {
        state = $1; nodes = $2 + 0; gres = $3
        sub(/[*~#$@%+-]+$/, "", state)
        gpus_per_node = 4
        if (match(gres, /gpu:([0-9]+)/, arr)) gpus_per_node = arr[1]
        state_nodes[state] += nodes
        state_gpus[state]  += nodes * gpus_per_node
        total_nodes += nodes
        total_gpus  += nodes * gpus_per_node
    }
    END {
        alloc      = state_nodes["allocated"]  + 0
        mixed      = state_nodes["mixed"]      + 0
        completing = state_nodes["completing"] + 0
        idle_n     = state_nodes["idle"]       + 0
        down_raw   = state_nodes["down"]       + 0
        drained    = state_nodes["drained"]    + 0
        draining   = state_nodes["draining"]   + 0
        maint      = state_nodes["maint"]      + 0
        reserved   = state_nodes["reserved"]   + 0
        planned    = state_nodes["planned"]    + 0

        active_n = alloc + mixed + completing
        active_g = state_gpus["allocated"] + state_gpus["mixed"] + state_gpus["completing"] + 0
        down_n   = down_raw + drained + draining + maint
        down_g   = state_gpus["down"] + state_gpus["drained"] + state_gpus["draining"] + state_gpus["maint"] + 0
        idle_g   = state_gpus["idle"] + 0
        other_n  = total_nodes - active_n - idle_n - down_n

        printf "%d %d %d %d %d %d %d %d %d %d %d %d %d %d %d %d %d %d",
            total_nodes, total_gpus,
            active_n, active_g, alloc, mixed, completing,
            idle_n, idle_g,
            down_n, down_g, down_raw, drained, draining, maint,
            other_n, reserved, planned
    }')

    local total_nodes total_gpus
    local active_n active_g alloc_n mixed_n completing_n
    local idle_n idle_g
    local down_n down_g down_raw drained_n draining_n maint_n
    local other_n reserved_n planned_n
    read -r total_nodes total_gpus \
        active_n active_g alloc_n mixed_n completing_n \
        idle_n idle_g \
        down_n down_g down_raw drained_n draining_n maint_n \
        other_n reserved_n planned_n <<< "$cluster_stats"

    # Integer percentages of total cluster nodes
    local active_pct=0 idle_pct=0 down_pct=0
    if [[ ${total_nodes:-0} -gt 0 ]]; then
        active_pct=$(( 100 * active_n / total_nodes ))
        idle_pct=$((   100 * idle_n   / total_nodes ))
        down_pct=$((   100 * down_n   / total_nodes ))
    fi

    # Build "N label + M label" breakdown strings, omitting zero components.
    local active_bd="" down_bd="" other_bd=""
    [[ ${alloc_n:-0}      -gt 0 ]] && active_bd="${alloc_n} alloc"
    [[ ${mixed_n:-0}      -gt 0 ]] && active_bd="${active_bd:+${active_bd} + }${mixed_n} mixed"
    [[ ${completing_n:-0} -gt 0 ]] && active_bd="${active_bd:+${active_bd} + }${completing_n} completing"
    [[ ${down_raw:-0}     -gt 0 ]] && down_bd="${down_raw} down"
    [[ ${drained_n:-0}    -gt 0 ]] && down_bd="${down_bd:+${down_bd} + }${drained_n} drained"
    [[ ${draining_n:-0}   -gt 0 ]] && down_bd="${down_bd:+${down_bd} + }${draining_n} draining"
    [[ ${maint_n:-0}      -gt 0 ]] && down_bd="${down_bd:+${down_bd} + }${maint_n} maint"
    [[ ${reserved_n:-0}   -gt 0 ]] && other_bd="${reserved_n} reserved"
    [[ ${planned_n:-0}    -gt 0 ]] && other_bd="${other_bd:+${other_bd} + }${planned_n} planned"

    local effective_n=$(( total_nodes - down_n - other_n ))
    local headroom=$((MAX_NODES - current_nodes))
    if [[ $headroom -lt 0 ]]; then headroom=0; fi
    local after_submit=$((current_nodes + requested_nodes))

    echo "──────────────────────────────────────────────────────────────────" >&2
    printf "  Cluster:  %d nodes / %d GPUs  (%d schedulable)\n" \
        "$total_nodes" "$total_gpus" "$effective_n" >&2
    printf "    %-7s %5d  %-6s%s\n" \
        "active" "$active_n" "($active_pct%)" "${active_bd:+   ${active_bd}}" >&2
    printf "    %-7s %5d  %-6s\n" \
        "idle" "$idle_n" "($idle_pct%)" >&2
    printf "    %-7s %5d  %-6s%s\n" \
        "down" "$down_n" "($down_pct%)" "${down_bd:+   ${down_bd}}" >&2
    if [[ ${other_n:-0} -gt 0 ]]; then
        printf "    %-7s %5d  %-6s%s\n" \
            "other" "$other_n" "" "${other_bd:+   ${other_bd}}" >&2
    fi
    echo "  Account:  ${current_nodes} nodes used by $ACCOUNT  (limit: $MAX_NODES, headroom: $headroom)" >&2

    local breakdown
    breakdown=$(get_per_user_breakdown)
    if [[ -n "$breakdown" ]]; then
        echo "$breakdown" >&2
    fi

    echo "  Request:  +${requested_nodes} nodes  →  ${after_submit}/${MAX_NODES}" >&2

    # Bad-node exclusion summary: how many nodes are currently in the TTL window
    # and a hint for reporting new ones.
    local bad_count
    bad_count=$(bad_nodes_read_active 2>/dev/null | wc -l | tr -d ' ')
    bad_count="${bad_count:-0}"
    local ttl_str
    if (( BAD_NODES_TTL >= 86400 )); then
        ttl_str="$((BAD_NODES_TTL / 86400))d"
    elif (( BAD_NODES_TTL >= 3600 )); then
        ttl_str="$((BAD_NODES_TTL / 3600))h"
    else
        ttl_str="${BAD_NODES_TTL}s"
    fi
    if (( bad_count > 0 )); then
        echo "  Bad nodes: ${bad_count} excluded (last ${ttl_str})  —  file: ${BAD_NODES_FILE}" >&2
        echo "             report more: isambard_sbatch --mark-bad <node> [reason]" >&2
    else
        echo "  Bad nodes: none in last ${ttl_str}  —  file: ${BAD_NODES_FILE}" >&2
        echo "             report one: isambard_sbatch --mark-bad <node> [reason]" >&2
    fi

    echo "──────────────────────────────────────────────────────────────────" >&2
}

# Check if --wrap was passed on the command line.
has_wrap_arg() {
    for arg in "$@"; do
        case "$arg" in
            --wrap=*|--wrap) return 0 ;;
        esac
    done
    return 1
}

# ─────────────────────────────────────────────────────────────────────────────
# Bad-nodes exclusion
#
# A shared, append-only log of compute nodes that the team has reported as
# broken. Each line: <epoch>\t<node>\t<reason>\t<user>. Entries older than
# BAD_NODES_TTL seconds are ignored. The wrapper reads active entries and
# merges them into SLURM's --exclude argument before submission.
#
# This feature must never block a submission: on any error (missing file,
# awk failure, unwritable path), fall back silently to the original argv.
# ─────────────────────────────────────────────────────────────────────────────

# Resolved path to the shared log.
bad_nodes_file_path() {
    echo "$BAD_NODES_FILE"
}

# Read active (non-expired) bad nodes, deduped. One node per line on stdout.
# Silent no-op if the file is missing or unreadable.
bad_nodes_read_active() {
    [[ -r "$BAD_NODES_FILE" ]] || return 0
    local now
    now=$(date +%s 2>/dev/null) || return 0
    awk -F'\t' -v now="$now" -v ttl="$BAD_NODES_TTL" '
        $1 ~ /^[0-9]+$/ && $2 != "" && (now - $1) < ttl {
            if (!seen[$2]++) print $2
        }
    ' "$BAD_NODES_FILE" 2>/dev/null || true
}

# Append a bad-node entry. Usage: bad_nodes_mark <node> [reason]
bad_nodes_mark() {
    local node="${1:-}"
    local reason="${2:-}"

    if [[ -z "$node" ]]; then
        echo "isambard_sbatch --mark-bad: error: missing node name" >&2
        echo "  Usage: isambard_sbatch --mark-bad <node> [reason]" >&2
        return 2
    fi
    if ! [[ "$node" =~ ^[A-Za-z0-9._-]+$ ]]; then
        echo "isambard_sbatch --mark-bad: error: invalid node name '$node'" >&2
        echo "  Allowed characters: letters, digits, '.', '_', '-'" >&2
        return 2
    fi

    # Strip tabs and newlines from reason so they can't corrupt the record format
    reason="${reason//$'\t'/ }"
    reason="${reason//$'\n'/ }"

    local dir
    dir=$(dirname "$BAD_NODES_FILE")
    if [[ ! -d "$dir" ]]; then
        echo "isambard_sbatch --mark-bad: error: directory does not exist: $dir" >&2
        return 1
    fi

    # Create file with group-writable perms if missing
    if [[ ! -e "$BAD_NODES_FILE" ]]; then
        if ! ( umask 002; : > "$BAD_NODES_FILE" ) 2>/dev/null; then
            echo "isambard_sbatch --mark-bad: error: cannot create $BAD_NODES_FILE" >&2
            return 1
        fi
        chmod 664 "$BAD_NODES_FILE" 2>/dev/null || true
    fi

    local epoch
    epoch=$(date +%s)
    # Single printf ≤ PIPE_BUF is atomic on O_APPEND (Linux) — no flock needed
    if ! printf '%s\t%s\t%s\t%s\n' "$epoch" "$node" "$reason" "${USER:-unknown}" >> "$BAD_NODES_FILE"; then
        echo "isambard_sbatch --mark-bad: error: cannot append to $BAD_NODES_FILE" >&2
        return 1
    fi

    echo "isambard_sbatch: marked '$node' as bad${reason:+ (${reason})} in $BAD_NODES_FILE" >&2
    return 0
}

# Print active bad-node entries in human-readable form.
bad_nodes_list() {
    if [[ ! -r "$BAD_NODES_FILE" ]]; then
        echo "isambard_sbatch --list-bad: no bad-nodes file at $BAD_NODES_FILE" >&2
        return 0
    fi

    local now
    now=$(date +%s)
    local found=0
    local epoch node reason user
    while IFS=$'\t' read -r epoch node reason user; do
        [[ "$epoch" =~ ^[0-9]+$ ]] || continue
        [[ -n "$node" ]] || continue
        (( now - epoch < BAD_NODES_TTL )) || continue
        local when
        when=$(date -d "@$epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "$epoch")
        printf '  %s  %-24s  %-40s  (%s)\n' "$when" "$node" "${reason:--}" "${user:-?}"
        found=1
    done < "$BAD_NODES_FILE"

    if [[ $found -eq 0 ]]; then
        echo "isambard_sbatch --list-bad: no active bad-node entries (TTL: ${BAD_NODES_TTL}s)" >&2
    fi
    return 0
}

# Internal: atomically rewrite BAD_NODES_FILE with filtered content from stdin.
# Writes to a temp file in the same directory, then renames over the original.
# This is the POSIX safe-rewrite pattern (rename is atomic on a single filesystem).
_bad_nodes_rewrite_from_stdin() {
    local dir
    dir=$(dirname "$BAD_NODES_FILE")
    local tmpfile
    tmpfile=$(mktemp "${dir}/.isambard_sbatch_bn.XXXXXX" 2>/dev/null) || {
        echo "isambard_sbatch: error: cannot create temp file in $dir" >&2
        return 1
    }
    # Copy stdin to temp file
    cat > "$tmpfile" || {
        rm -f "$tmpfile"
        echo "isambard_sbatch: error: cannot write to temp file" >&2
        return 1
    }
    chmod 664 "$tmpfile" 2>/dev/null || true
    if ! mv -f "$tmpfile" "$BAD_NODES_FILE"; then
        rm -f "$tmpfile"
        echo "isambard_sbatch: error: cannot replace $BAD_NODES_FILE" >&2
        return 1
    fi
    return 0
}

# Remove ALL entries (active and expired) for a given node. Usage:
#   bad_nodes_unmark <node>
bad_nodes_unmark() {
    local node="${1:-}"

    if [[ -z "$node" ]]; then
        echo "isambard_sbatch --unmark-bad: error: missing node name" >&2
        echo "  Usage: isambard_sbatch --unmark-bad <node>" >&2
        return 2
    fi
    if ! [[ "$node" =~ ^[A-Za-z0-9._-]+$ ]]; then
        echo "isambard_sbatch --unmark-bad: error: invalid node name '$node'" >&2
        return 2
    fi

    if [[ ! -r "$BAD_NODES_FILE" ]]; then
        echo "isambard_sbatch --unmark-bad: no bad-nodes file at $BAD_NODES_FILE" >&2
        return 0
    fi

    # Count matches first so we can report how many we removed
    local removed
    removed=$(awk -F'\t' -v n="$node" '$2 == n' "$BAD_NODES_FILE" 2>/dev/null | wc -l | tr -d ' ')
    removed="${removed:-0}"

    if [[ "$removed" -eq 0 ]]; then
        echo "isambard_sbatch --unmark-bad: no entries found for '$node' in $BAD_NODES_FILE" >&2
        return 0
    fi

    # Rewrite the file excluding matching lines
    awk -F'\t' -v n="$node" '$2 != n' "$BAD_NODES_FILE" | _bad_nodes_rewrite_from_stdin || return 1

    echo "isambard_sbatch: unmarked '$node' (${removed} entries removed) from $BAD_NODES_FILE" >&2
    return 0
}

# Replace: remove all existing entries for a node and append a fresh one.
# Usage: bad_nodes_update <node> <new reason>
bad_nodes_update() {
    local node="${1:-}"
    local reason="${2:-}"

    if [[ -z "$node" ]]; then
        echo "isambard_sbatch --update-bad: error: missing node name" >&2
        echo "  Usage: isambard_sbatch --update-bad <node> <new reason>" >&2
        return 2
    fi
    if ! [[ "$node" =~ ^[A-Za-z0-9._-]+$ ]]; then
        echo "isambard_sbatch --update-bad: error: invalid node name '$node'" >&2
        return 2
    fi

    # Strip tabs/newlines from reason
    reason="${reason//$'\t'/ }"
    reason="${reason//$'\n'/ }"

    local dir
    dir=$(dirname "$BAD_NODES_FILE")
    if [[ ! -d "$dir" ]]; then
        echo "isambard_sbatch --update-bad: error: directory does not exist: $dir" >&2
        return 1
    fi

    # Create file if missing — then update = just a mark
    if [[ ! -e "$BAD_NODES_FILE" ]]; then
        bad_nodes_mark "$node" "$reason"
        return $?
    fi

    local removed
    removed=$(awk -F'\t' -v n="$node" '$2 == n' "$BAD_NODES_FILE" 2>/dev/null | wc -l | tr -d ' ')
    removed="${removed:-0}"

    local epoch
    epoch=$(date +%s)

    # Build new content: all non-matching lines, then the new entry
    {
        awk -F'\t' -v n="$node" '$2 != n' "$BAD_NODES_FILE"
        printf '%s\t%s\t%s\t%s\n' "$epoch" "$node" "$reason" "${USER:-unknown}"
    } | _bad_nodes_rewrite_from_stdin || return 1

    if [[ "$removed" -eq 0 ]]; then
        echo "isambard_sbatch: updated '$node' (no prior entries — added fresh) in $BAD_NODES_FILE" >&2
    else
        echo "isambard_sbatch: updated '$node' (replaced ${removed} prior entries) in $BAD_NODES_FILE" >&2
    fi
    return 0
}

# Housekeeping: drop all expired entries from the file. Keeps the log from
# growing indefinitely (the read-side filter already hides them, but the
# file itself retains history forever without this).
bad_nodes_prune() {
    if [[ ! -r "$BAD_NODES_FILE" ]]; then
        echo "isambard_sbatch --prune-bad: no bad-nodes file at $BAD_NODES_FILE" >&2
        return 0
    fi

    local now
    now=$(date +%s)
    local before after
    before=$(wc -l < "$BAD_NODES_FILE" | tr -d ' ')
    before="${before:-0}"

    # Keep only lines with a valid, fresh epoch
    awk -F'\t' -v now="$now" -v ttl="$BAD_NODES_TTL" '
        $1 ~ /^[0-9]+$/ && (now - $1) < ttl { print }
    ' "$BAD_NODES_FILE" | _bad_nodes_rewrite_from_stdin || return 1

    after=$(wc -l < "$BAD_NODES_FILE" | tr -d ' ')
    after="${after:-0}"
    local removed=$((before - after))

    echo "isambard_sbatch --prune-bad: removed ${removed} expired/malformed lines (kept ${after}) in $BAD_NODES_FILE" >&2
    return 0
}

# Rewrite argv to merge cached bad nodes into --exclude.
# Reads original argv from "$@"; emits new argv NUL-separated on stdout.
# Callers should read back with: mapfile -d '' -t new_args < <(bad_nodes_inject_exclude "$@")
# On any failure, emits the original argv unchanged.
bad_nodes_inject_exclude() {
    local bad_list
    bad_list=$(bad_nodes_read_active 2>/dev/null | paste -sd, - 2>/dev/null) || bad_list=""

    # Fast path: no cached bad nodes — leave argv completely untouched
    if [[ -z "$bad_list" ]]; then
        local a
        for a in "$@"; do
            printf '%s\0' "$a"
        done
        return 0
    fi

    local -a new_args=()
    local -a user_excludes=()
    local args=("$@")
    local i=0 arg

    while [[ $i -lt ${#args[@]} ]]; do
        arg="${args[$i]}"
        case "$arg" in
            --exclude=*)
                user_excludes+=("${arg#--exclude=}")
                ;;
            --exclude|-x)
                i=$((i + 1))
                if [[ $i -lt ${#args[@]} ]]; then
                    user_excludes+=("${args[$i]}")
                fi
                ;;
            -x=*)
                user_excludes+=("${arg#-x=}")
                ;;
            -x?*)
                user_excludes+=("${arg#-x}")
                ;;
            *)
                new_args+=("$arg")
                ;;
        esac
        i=$((i + 1))
    done

    # Build final --exclude value. Strategy:
    #  - bad_list is a CSV of single node names (no commas/brackets in each name)
    #    that's already been deduped by bad_nodes_read_active.
    #  - User excludes are treated as opaque atoms: we do NOT split on commas,
    #    because SLURM accepts bracket ranges like "nid[001,003,005]" whose
    #    internal commas must be preserved.
    #  - Concatenate user excludes after bad_list. SLURM tolerates duplicates.
    local merged="$bad_list"
    local e
    if [[ ${#user_excludes[@]} -gt 0 ]]; then
        for e in "${user_excludes[@]}"; do
            [[ -n "$e" ]] || continue
            if [[ -n "$merged" ]]; then
                merged="${merged},${e}"
            else
                merged="$e"
            fi
        done
    fi

    local a
    for a in "${new_args[@]}"; do
        printf '%s\0' "$a"
    done
    if [[ -n "$merged" ]]; then
        printf '%s\0' "--exclude=$merged"
    fi
    return 0
}

check_mode() {
    # Lightweight check: is the account currently over the node limit?
    # Used by in-script guards to abort jobs submitted via raw /usr/bin/sbatch.
    # Respects ISAMBARD_SBATCH_FORCE but ignores ISAMBARD_SBATCH_DISABLED (separate defense layer).

    if [[ "$FORCE" == "1" ]]; then
        echo "isambard_sbatch --check: OK (forced) — account=$ACCOUNT, limit=$MAX_NODES" >&2
        exit 0
    fi

    local current_nodes
    current_nodes=$(get_current_nodes)

    if [[ $current_nodes -gt $MAX_NODES ]]; then
        echo "isambard_sbatch --check: BLOCKED — account=$ACCOUNT using $current_nodes nodes (limit: $MAX_NODES)" >&2
        echo "  Cancel pending jobs or raise ISAMBARD_SBATCH_MAX_NODES to unblock." >&2
        exit 1
    fi

    echo "isambard_sbatch --check: OK — account=$ACCOUNT using $current_nodes/$MAX_NODES nodes" >&2
    exit 0
}

main() {
    # Pass through immediately if disabled
    if [[ "$DISABLED" == "1" ]]; then
        exec "$REAL_SBATCH" "$@"
    fi

    # Pass through if forced
    if [[ "$FORCE" == "1" ]]; then
        local -a forced_args=()
        mapfile -d '' -t forced_args < <(bad_nodes_inject_exclude "$@")
        if [[ "$DRY_RUN" == "1" ]]; then
            echo "[DRY RUN] [FORCED] Would submit: $REAL_SBATCH ${forced_args[*]}"
            exit 0
        fi
        exec "$REAL_SBATCH" "${forced_args[@]}"
    fi

    # Parse requested nodes from CLI args (CLI overrides script directives)
    local requested_nodes
    requested_nodes=$(parse_nodes_from_args "$@")

    local script_file
    script_file=$(find_script_file "$@")

    # If not specified on CLI, check the batch script
    if [[ -z "$requested_nodes" && -n "$script_file" ]]; then
        requested_nodes=$(parse_nodes_from_script "$script_file")
    fi

    # Default to 1 node if not specified anywhere
    requested_nodes="${requested_nodes:-1}"

    # Handle node ranges
    requested_nodes=$(resolve_node_count "$requested_nodes")

    # Validate that requested_nodes is a number
    if ! [[ "$requested_nodes" =~ ^[0-9]+$ ]]; then
        echo "isambard_sbatch: warning: could not parse node count '$requested_nodes', defaulting to 1" >&2
        requested_nodes=1
    fi

    # Get current usage for the account
    local current_nodes
    current_nodes=$(get_current_nodes)

    local total=$((current_nodes + requested_nodes))

    # Always print cluster summary
    print_cluster_summary "$current_nodes" "$requested_nodes"

    # Exit early if no script and no --wrap — real sbatch would hang on stdin
    if [[ -z "$script_file" ]] && ! has_wrap_arg "$@"; then
        echo "" >&2
        echo "  No batch script or --wrap provided. Nothing to submit." >&2
        echo "" >&2
        echo "  Usage: isambard_sbatch [OPTIONS...] <script> [args...]" >&2
        echo "         isambard_sbatch [OPTIONS...] --wrap=\"command\"" >&2
        echo "" >&2
        exit 1
    fi

    if [[ $total -gt $MAX_NODES ]]; then
        echo "" >&2
        echo "  BLOCKED — would exceed project node limit ($total > $MAX_NODES)" >&2
        echo "" >&2
        echo "  To proceed, either:" >&2
        echo "    - Wait for existing jobs to complete or cancel pending ones" >&2
        echo "    - Increase limit: export ISAMBARD_SBATCH_MAX_NODES=<N>" >&2
        echo "    - Force this submission: ISAMBARD_SBATCH_FORCE=1 isambard_sbatch ..." >&2
        echo "" >&2
        exit 1
    fi

    # Rebuild argv with bad-node exclusions merged into --exclude.
    # Safe no-op if the shared file is missing or empty.
    local -a submit_args=()
    mapfile -d '' -t submit_args < <(bad_nodes_inject_exclude "$@")

    # Dry run: report what would happen
    if [[ "$DRY_RUN" == "1" ]]; then
        echo "[DRY RUN] Would submit: $REAL_SBATCH ${submit_args[*]}" >&2
        exit 0
    fi

    # All checks passed — submit
    exec "$REAL_SBATCH" "${submit_args[@]}"
}

# Allow sourcing for unit tests
if [[ "${1:-}" == "--source-only" ]]; then
    return 0 2>/dev/null || true
elif [[ "${1:-}" == "--check" ]]; then
    check_mode
elif [[ "${1:-}" == "--mark-bad" ]]; then
    bad_nodes_mark "${2:-}" "${3:-}"
    exit $?
elif [[ "${1:-}" == "--list-bad" ]]; then
    bad_nodes_list
    exit $?
elif [[ "${1:-}" == "--update-bad" ]]; then
    bad_nodes_update "${2:-}" "${3:-}"
    exit $?
elif [[ "${1:-}" == "--unmark-bad" ]]; then
    bad_nodes_unmark "${2:-}"
    exit $?
elif [[ "${1:-}" == "--prune-bad" ]]; then
    bad_nodes_prune
    exit $?
else
    main "$@"
fi
